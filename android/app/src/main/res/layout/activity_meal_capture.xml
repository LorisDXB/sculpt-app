<?xml version="1.0" encoding="utf-8"?>
<FrameLayout xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#FF050816">

    <androidx.camera.view.PreviewView
        android:id="@+id/camera_preview_view"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:implementationMode="performance"
        app:scaleType="fillCenter" />

    <ImageView
        android:id="@+id/captured_image_preview"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:adjustViewBounds="false"
        android:contentDescription="@string/meal_capture_preview_content_description"
        android:scaleType="centerCrop"
        android:visibility="gone" />

    <TextView
        android:id="@+id/camera_status_text"
        android:layout_width="wrap_content"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom|center_horizontal"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="124dp"
        android:background="@drawable/capture_status_background"
        android:paddingStart="16dp"
        android:paddingTop="8dp"
        android:paddingEnd="16dp"
        android:paddingBottom="8dp"
        android:text="@string/meal_capture_live_hint"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp"
        android:visibility="gone" />

    <TextView
        android:id="@+id/camera_transcript_text"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:layout_marginStart="24dp"
        android:layout_marginEnd="24dp"
        android:layout_marginBottom="128dp"
        android:background="@drawable/capture_status_background"
        android:gravity="center"
        android:paddingStart="16dp"
        android:paddingTop="12dp"
        android:paddingEnd="16dp"
        android:paddingBottom="12dp"
        android:textColor="#FFFFFFFF"
        android:textSize="14sp"
        android:visibility="gone" />

    <FrameLayout
        android:id="@+id/capture_bottom_bar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:layout_gravity="bottom"
        android:paddingStart="24dp"
        android:paddingTop="20dp"
        android:paddingEnd="24dp"
        android:paddingBottom="28dp">

        <ImageButton
            android:id="@+id/camera_back_button"
            android:layout_width="56dp"
            android:layout_height="56dp"
            android:layout_gravity="center_vertical|start"
            android:background="@drawable/capture_control_background"
            android:contentDescription="@string/meal_capture_back"
            android:padding="16dp"
            android:scaleType="centerInside"
            android:src="@drawable/ic_capture_back"
            android:tint="#FFFFFFFF" />

        <LinearLayout
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"
            android:gravity="center_vertical"
            android:orientation="horizontal">

            <View
                android:layout_width="72dp"
                android:layout_height="1dp" />

            <ImageButton
                android:id="@+id/camera_primary_button"
                android:layout_width="72dp"
                android:layout_height="72dp"
                android:background="@drawable/capture_primary_button_background"
                android:contentDescription="@string/meal_capture_take_photo"
                android:padding="20dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_capture_camera"
                android:tint="#FF06111F" />

            <ImageButton
                android:id="@+id/camera_microphone_button"
                android:layout_width="56dp"
                android:layout_height="56dp"
                android:layout_marginStart="16dp"
                android:background="@drawable/capture_control_background"
                android:contentDescription="@string/meal_capture_microphone"
                android:padding="16dp"
                android:scaleType="centerInside"
                android:src="@drawable/ic_capture_microphone"
                android:tint="#FFFFFFFF"
                android:visibility="invisible" />
        </LinearLayout>
    </FrameLayout>

</FrameLayout>
